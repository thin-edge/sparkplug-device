# spdevice configuration
# Environment variables are read directly by the binary.
# CLI flags take precedence over environment variables, which take precedence
# over built-in defaults.
#
# Supported variables:
#   SPDEVICE_BROKER   -- MQTT broker address (host:port)
#   SPDEVICE_MODE     -- publish mode: "sparkplug" or "tedge"
#   SPDEVICE_GROUP    -- Sparkplug B Group ID (sparkplug mode only)
#   SPDEVICE_NODE     -- edge node / device ID
#   SPDEVICE_INTERVAL -- publish interval (e.g. 5s, 1s, 500ms)
#   SPDEVICE_HEADLESS -- run without TUI: "true" or "1"
#
# To apply changes: systemctl restart spdevice

SPDEVICE_BROKER=localhost:1883
SPDEVICE_MODE=sparkplug
SPDEVICE_GROUP=tedge
SPDEVICE_NODE=sim-cnc01
SPDEVICE_INTERVAL=5s
SPDEVICE_HEADLESS=true
